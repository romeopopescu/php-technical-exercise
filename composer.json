{
    "name": "acmelearn/user-importer",
    "description": "Web tool that imports staff users from an HR CSV export into the platform user store.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "webonyx/graphql-php": "^15.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "AcmeLearn\\Importer\\": "src/",
            "AcmeLearn\\Importer\\Api\\": "api/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AcmeLearn\\Importer\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
